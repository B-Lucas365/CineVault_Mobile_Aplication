  "info": {
    "title": "CineVault API",
    "description": "Backend do CineVault — auth, settings, coleções.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Ada Lovelace",
            "minLength": 2,
            "maxLength": 80
          },
          "email": {
            "type": "string",
            "example": "ada@mail.com"
          },
          "password": {
            "type": "string",
            "example": "senhaForte123",
            "minLength": 8
          }
        },
        "required": [
          "fullName",
          "email",
          "password"
        ]
      },
      "UserEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "clx1abc000001"
          },
          "email": {
            "type": "string",
            "example": "ada@mail.com"
          },
          "fullName": {
            "type": "string",
            "example": "Ada Lovelace"
          },
          "avatarUrl": {
            "type": "object",
            "example": null,
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-01-15T10:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-01-15T10:00:00.000Z"
          }
        },
        "required": [
          "id",
          "email",
          "fullName",
          "avatarUrl",
          "createdAt",
          "updatedAt"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserEntity"
          },
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIs..."
          },
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIs..."
          }
        },
        "required": [
          "user",
          "accessToken",
          "refreshToken"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "ada@mail.com"
          },
          "password": {
            "type": "string",
            "example": "senhaForte123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIs..."
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "TokenPairDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIs..."
          },
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIs..."
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Ada Byron",
            "minLength": 2,
            "maxLength": 80
          },
          "avatarUrl": {
            "type": "string",
            "example": "https://cdn.app/avatar.png",
            "nullable": true
          }
        }
      },
      "UserSettingsEntity": {
        "type": "object",
        "properties": {
          "theme": {
            "type": "string",
            "enum": [
              "system",
              "light",
              "dark"
            ],
            "example": "system"
          },
          "language": {
            "type": "string",
            "example": "pt-BR"
          },
          "autoplayTrailers": {
            "type": "boolean",
            "example": true
          },
          "adultContent": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "theme",
          "language",
          "autoplayTrailers",
          "adultContent"
        ]
      },
      "UpdateSettingsDto": {
        "type": "object",
        "properties": {
          "theme": {
            "type": "string",
            "enum": [
              "system",
              "light",
              "dark"
            ],
            "example": "dark"
          },
          "language": {
            "type": "string",
            "example": "en-US"
          },
          "autoplayTrailers": {
            "type": "boolean",
            "example": false
          },
          "adultContent": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "FavoriteEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "clf1abc000001"
          },
          "tmdbId": {
            "type": "number",
            "example": 693134
          },
          "mediaType": {
            "type": "string",
            "enum": [
              "movie",
              "tv"
            ],
            "example": "movie"
          },
          "title": {
            "type": "string",
            "example": "Dune: Part Two"
          },
          "posterPath": {
            "type": "object",
            "example": "/poster.jpg",
            "nullable": true
          },
          "backdropPath": {
            "type": "object",
            "example": "/backdrop.jpg",
            "nullable": true
          },
          "releaseYear": {
            "type": "object",
            "example": 2024,
            "nullable": true
          },
          "voteAverage": {
            "type": "object",
            "example": 8.4,
            "nullable": true
          },
          "addedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-01-15T10:00:00.000Z"
          }
        },
        "required": [
          "id",
          "tmdbId",
          "mediaType",
          "title",
          "posterPath",
          "backdropPath",
          "releaseYear",
          "voteAverage",
          "addedAt"
        ]
      },
      "MediaSnapshotDto": {
        "type": "object",
        "properties": {
          "tmdbId": {
            "type": "number",
            "example": 693134
          },
          "mediaType": {
            "type": "string",
            "enum": [
              "movie",
              "tv"
            ],
            "example": "movie"
          },
          "title": {
            "type": "string",
            "example": "Dune: Part Two"
          },
          "posterPath": {
            "type": "object",
            "example": "/poster.jpg",
            "nullable": true
          },
          "backdropPath": {
            "type": "object",
            "example": "/backdrop.jpg",
            "nullable": true
          },
          "releaseYear": {
            "type": "object",
            "example": 2024,
            "nullable": true
          },
          "voteAverage": {
            "type": "object",
            "example": 8.4,
            "nullable": true
          }
        },
        "required": [
          "tmdbId",
          "mediaType",
          "title"
        ]
      },
      "SavedEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "cls1abc000001"
          },
          "tmdbId": {
            "type": "number",
            "example": 693134
          },
          "mediaType": {
            "type": "string",
            "enum": [
              "movie",
              "tv"
            ],
            "example": "movie"
          },
          "title": {
            "type": "string",
            "example": "Dune: Part Two"
          },
          "posterPath": {
            "type": "object",
            "example": "/poster.jpg",
            "nullable": true
          },
          "backdropPath": {
            "type": "object",
            "example": "/backdrop.jpg",
            "nullable": true
          },
          "releaseYear": {
            "type": "object",
            "example": 2024,
            "nullable": true
          },
          "voteAverage": {
            "type": "object",
            "example": 8.4,
            "nullable": true
          },
          "savedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-01-15T10:00:00.000Z"
          }
        },
        "required": [
          "id",
          "tmdbId",
          "mediaType",
          "title",
          "posterPath",
          "backdropPath",
          "releaseYear",
          "voteAverage",
          "savedAt"
        ]
      },
      "ContinueWatchingEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "clc1abc000001"
          },
          "tmdbId": {
            "type": "number",
            "example": 12345
          },
          "mediaType": {
            "type": "string",
            "enum": [
              "movie",
              "tv"
            ],
            "example": "tv"
          },
