    "/api/v1/favorites": {
      "get": {
        "operationId": "FavoritesController_list",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Itens por página. Acima de 50 é capado em 50.",
            "schema": {
              "minimum": 1,
              "maximum": 50,
              "default": 20,
              "example": 20,
              "type": "number"
            }
          },
          {
            "name": "mediaType",
            "required": false,
            "in": "query",
            "schema": {
              "example": "movie",
              "enum": [
                "movie",
                "tv"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FavoriteEntity"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Lista a watchlist (paginada, filtro por mediaType)",
        "tags": [
          "favorites"
        ]
      },
      "post": {
        "operationId": "FavoritesController_add",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MediaSnapshotDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FavoriteEntity"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Adiciona à watchlist (idempotente: 200 se já existir)",
        "tags": [
          "favorites"
        ]
      }
    },
    "/api/v1/favorites/{tmdbId}": {
      "delete": {
        "operationId": "FavoritesController_remove",
